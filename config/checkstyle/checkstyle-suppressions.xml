<?xml version="1.0"?>
<!DOCTYPE suppressions PUBLIC
    "-//Checkstyle//DTD SuppressionFilter Configuration 1.2//EN"
    "https://checkstyle.org/dtds/suppressions_1_2.dtd">

<suppressions>
    <!-- Não exigir Javadoc para classes óbvias -->
    <suppress checks="MissingJavadocType" files=".*Application\.java"/>
    <suppress checks="MissingJavadocType" files=".*Config\.java"/>
    <suppress checks="MissingJavadocType" files=".*Entity\.java"/>
    <suppress checks="MissingJavadocType" files=".*Repository\.java"/>
    <suppress checks="MissingJavadocType" files=".*Request\.java"/>
    <suppress checks="MissingJavadocType" files=".*Response\.java"/>
    <suppress checks="MissingJavadocType" files=".*Exception\.java"/>

    <!-- Não exigir Javadoc para métodos simples -->
    <suppress checks="MissingJavadocMethod" files=".*Entity\.java"/>
    <suppress checks="MissingJavadocMethod" files=".*Request\.java"/>
    <suppress checks="MissingJavadocMethod" files=".*Response\.java"/>

    <!-- Suprimir regras comuns para classes de teste (arquivos terminados em Test.java) -->
    <suppress checks="MissingJavadocType" files=".*Test\.java"/>
    <suppress checks="MissingJavadocMethod" files=".*Test\.java"/>
    <suppress checks="MethodName" files=".*Test\.java"/>
    <suppress checks="LineLength" files=".*Test\.java"/>
    <suppress checks="MethodLength" files=".*Test\.java"/>

</suppressions>
